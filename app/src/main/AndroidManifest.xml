<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">


    <!-- Biometric / Fingerprint permission -->
    <uses-permission android:name="android.permission.USE_BIOMETRIC" />
    <uses-permission android:name="android.permission.USE_FINGERPRINT" />


    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.PersonalFinanceApp">

        <activity
            android:name=".ui.auth.PinActivity"
            android:exported="false" />


        <!-- Force light mode always — ignores phone dark mode setting -->
        <meta-data
            android:name="android.app.ui.mode"
            android:value="day"/>

        <activity
            android:name=".ui.auth.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.PersonalFinanceApp.NoActionBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.auth.LoginActivity"
            android:exported="false"
            android:theme="@style/Theme.PersonalFinanceApp.NoActionBar"/>

        <activity
            android:name=".ui.auth.RegisterActivity"
            android:exported="false"
            android:theme="@style/Theme.PersonalFinanceApp.NoActionBar"/>

        <activity
            android:name=".MainActivity"
            android:exported="false"
            android:configChanges="uiMode"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ui.transaction.AddTransactionActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"/>

    </application>

</manifest>