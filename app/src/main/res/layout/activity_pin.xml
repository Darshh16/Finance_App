<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <!-- Gold decorative circle -->
    <View
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:background="@drawable/circle_gold_bg"
        android:alpha="0.05"
        android:layout_marginTop="-100dp"
        android:layout_marginEnd="-100dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Lock icon -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardLock"
        android:layout_width="80dp"
        android:layout_height="80dp"
        app:cardCornerRadius="24dp"
        app:cardBackgroundColor="@color/navy_primary"
        app:cardElevation="12dp"
        android:layout_marginBottom="20dp"
        app:layout_constraintBottom_toTopOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed">
        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="🔐"
            android:textSize="32sp"/>
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Enter PIN"
        android:textColor="@color/text_primary"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"
        app:layout_constraintBottom_toTopOf="@id/tvSubtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/cardLock"/>

    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Enter your 4-digit PIN to continue"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:layout_marginBottom="32dp"
        app:layout_constraintBottom_toTopOf="@id/tvPinDots"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"/>

    <!-- PIN dots display -->
    <LinearLayout
        android:id="@+id/tvPinDots"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="32dp"
        app:layout_constraintBottom_toTopOf="@id/gridNumbers"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvSubtitle">
        <TextView android:id="@+id/dot1" android:layout_width="20dp" android:layout_height="20dp" android:background="@drawable/pin_dot_empty" android:layout_margin="8dp"/>
        <TextView android:id="@+id/dot2" android:layout_width="20dp" android:layout_height="20dp" android:background="@drawable/pin_dot_empty" android:layout_margin="8dp"/>
        <TextView android:id="@+id/dot3" android:layout_width="20dp" android:layout_height="20dp" android:background="@drawable/pin_dot_empty" android:layout_margin="8dp"/>
        <TextView android:id="@+id/dot4" android:layout_width="20dp" android:layout_height="20dp" android:background="@drawable/pin_dot_empty" android:layout_margin="8dp"/>
    </LinearLayout>

    <!-- Number Grid -->
    <GridLayout
        android:id="@+id/gridNumbers"
        android:layout_width="280dp"
        android:layout_height="wrap_content"
        android:columnCount="3"
        android:rowCount="4"
        android:layout_marginBottom="24dp"
        app:layout_constraintBottom_toTopOf="@id/btnFingerprint"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvPinDots">

        <!-- Row 1 -->
        <Button android:id="@+id/btn1" android:layout_width="0dp" android:layout_height="72dp" android:layout_columnWeight="1" android:text="1" android:textSize="22sp" android:textColor="@color/text_primary" android:backgroundTint="@color/bg_card" android:layout_margin="6dp" style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
        <Button android:id="@+id/btn2" android:layout_width="0dp" android:layout_height="72dp" android:layout_columnWeight="1" android:text="2" android:textSize="22sp" android:textColor="@color/text_primary" android:backgroundTint="@color/bg_card" android:layout_margin="6dp" style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
        <Button android:id="@+id/btn3" android:layout_width="0dp" android:layout_height="72dp" android:layout_columnWeight="1" android:text="3" android:textSize="22sp" android:textColor="@color/text_primary" android:backgroundTint="@color/bg_card" android:layout_margin="6dp" style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
        <!-- Row 2 -->
        <Button android:id="@+id/btn4" android:layout_width="0dp" android:layout_height="72dp" android:layout_columnWeight="1" android:text="4" android:textSize="22sp" android:textColor="@color/text_primary" android:backgroundTint="@color/bg_card" android:layout_margin="6dp" style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
        <Button android:id="@+id/btn5" android:layout_width="0dp" android:layout_height="72dp" android:layout_columnWeight="1" android:text="5" android:textSize="22sp" android:textColor="@color/text_primary" android:backgroundTint="@color/bg_card" android:layout_margin="6dp" style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
        <Button android:id="@+id/btn6" android:layout_width="0dp" android:layout_height="72dp" android:layout_columnWeight="1" android:text="6" android:textSize="22sp" android:textColor="@color/text_primary" android:backgroundTint="@color/bg_card" android:layout_margin="6dp" style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
        <!-- Row 3 -->
        <Button android:id="@+id/btn7" android:layout_width="0dp" android:layout_height="72dp" android:layout_columnWeight="1" android:text="7" android:textSize="22sp" android:textColor="@color/text_primary" android:backgroundTint="@color/bg_card" android:layout_margin="6dp" style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
        <Button android:id="@+id/btn8" android:layout_width="0dp" android:layout_height="72dp" android:layout_columnWeight="1" android:text="8" android:textSize="22sp" android:textColor="@color/text_primary" android:backgroundTint="@color/bg_card" android:layout_margin="6dp" style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
        <Button android:id="@+id/btn9" android:layout_width="0dp" android:layout_height="72dp" android:layout_columnWeight="1" android:text="9" android:textSize="22sp" android:textColor="@color/text_primary" android:backgroundTint="@color/bg_card" android:layout_margin="6dp" style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
        <!-- Row 4 -->
        <Button android:id="@+id/btnClear" android:layout_width="0dp" android:layout_height="72dp" android:layout_columnWeight="1" android:text="⌫" android:textSize="22sp" android:textColor="@color/expense_red" android:backgroundTint="@color/bg_card" android:layout_margin="6dp" style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
        <Button android:id="@+id/btn0" android:layout_width="0dp" android:layout_height="72dp" android:layout_columnWeight="1" android:text="0" android:textSize="22sp" android:textColor="@color/text_primary" android:backgroundTint="@color/bg_card" android:layout_margin="6dp" style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
        <Button android:id="@+id/btnOk" android:layout_width="0dp" android:layout_height="72dp" android:layout_columnWeight="1" android:text="✓" android:textSize="22sp" android:textColor="@color/gold" android:backgroundTint="@color/navy_primary" android:layout_margin="6dp"/>
    </GridLayout>

    <!-- Fingerprint button -->
    <Button
        android:id="@+id/btnFingerprint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Use Fingerprint 👆"
        android:textColor="@color/gold"
        android:backgroundTint="@color/bg_card"
        android:layout_marginBottom="40dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Error message -->
    <TextView
        android:id="@+id/tvError"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/expense_red"
        android:textSize="13sp"
        android:visibility="gone"
        android:layout_marginBottom="8dp"
        app:layout_constraintBottom_toTopOf="@id/gridNumbers"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
