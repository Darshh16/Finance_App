<resources>

    <!-- Dark theme — automatically used when dark mode is on -->
    <style name="Theme.PersonalFinanceApp"
        parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">#4A90D9</item>
        <item name="colorPrimaryVariant">#1A73E8</item>
        <item name="colorOnPrimary">@android:color/white</item>
        <item name="colorSecondary">#03DAC5</item>
        <item name="colorSurface">#1E1E1E</item>
        <item name="android:colorBackground">#121212</item>
        <item name="android:windowBackground">#121212</item>
        <item name="android:textColorPrimary">#FFFFFF</item>
        <item name="android:textColorSecondary">#AAAAAA</item>
    </style>

    <style name="Theme.PersonalFinanceApp.NoActionBar"
        parent="Theme.PersonalFinanceApp">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

</resources>
