<resources>
    <!-- Night theme — same dark design, slightly deeper -->
    <style name="Theme.PersonalFinanceApp"
        parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/navy_primary</item>
        <item name="colorPrimaryVariant">@color/navy_dark</item>
        <item name="colorOnPrimary">@color/text_primary</item>
        <item name="colorSecondary">@color/gold</item>
        <item name="colorOnSecondary">#000000</item>
        <item name="colorSurface">@color/bg_card</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:colorBackground">#0A0A1A</item>
        <item name="android:windowBackground">#0A0A1A</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
    </style>

    <style name="Theme.PersonalFinanceApp.NoActionBar"
        parent="Theme.PersonalFinanceApp">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>
</resources>
